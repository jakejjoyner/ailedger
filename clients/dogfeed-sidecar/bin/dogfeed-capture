#!/usr/bin/env python3
"""dogfeed-capture — Claude Code hook that appends one usage event to the
local sidecar queue.

Bob never sees an error from this script. Hard timeout 200ms, all failures
swallowed, exit 0 always. The drain script (dogfeed-drain) is responsible
for shipping events to AILedger; this script's job is "atomic append, then
disappear."

Hook envelope (stdin) is the standard Claude Code Stop / PostToolUse JSON.
We extract token + latency + model fields if present; otherwise we still
write a record with what we know (the AILedger receiver only requires a
small fixed shape).

Authority: ai-4vp / ADR-015. Bob's runtime must never block on this.
"""
from __future__ import annotations

import json
import os
import signal
import sys
import time
import uuid
from pathlib import Path

QUEUE_DIR = Path(os.environ.get("DOGFEED_QUEUE_DIR", Path.home() / "gt-lab" / ".dogfeed"))
QUEUE_FILE = QUEUE_DIR / "queue.jsonl"
TIMEOUT_S = 0.2  # 200ms hard cap per bead spec.


def _timeout_handler(_signum, _frame):  # pragma: no cover — signal callback
    sys.exit(0)


def _iso_now() -> str:
    # Fixed microsecond precision + Z suffix matches the proxy's regex.
    return time.strftime("%Y-%m-%dT%H:%M:%S", time.gmtime()) + ".000Z"


def _coerce_int(v) -> int:
    try:
        n = int(v)
        return n if n >= 0 else 0
    except (TypeError, ValueError):
        return 0


def _build_event(envelope: dict) -> dict:
    # Claude Code envelope shape varies (Stop vs PostToolUse). We hunt for
    # token + model fields in a few common places. Anything we can't find
    # gets a safe default — the receiver requires the shape, not deep
    # accuracy. The drain side ships whatever this writes.
    usage = (
        envelope.get("usage")
        or envelope.get("tool_use", {}).get("usage")
        or envelope.get("response", {}).get("usage")
        or {}
    )
    model = (
        envelope.get("model")
        or envelope.get("response", {}).get("model")
        or envelope.get("tool_use", {}).get("model")
        or "unknown"
    )
    tool_name = envelope.get("tool_name") or envelope.get("tool_use", {}).get("name")
    latency_ms = _coerce_int(
        envelope.get("latency_ms") or envelope.get("duration_ms") or 0
    )
    event = {
        "event_id": str(uuid.uuid4()),
        "ts": _iso_now(),
        "model": str(model),
        "input_tokens": _coerce_int(usage.get("input_tokens")),
        "output_tokens": _coerce_int(usage.get("output_tokens")),
        "latency_ms": latency_ms,
        "source": "claude-code",
    }
    if tool_name:
        event["tool_name"] = str(tool_name)
    return event


def _append(event: dict) -> None:
    QUEUE_DIR.mkdir(parents=True, exist_ok=True)
    line = json.dumps(event, separators=(",", ":")) + "\n"
    # O_APPEND on POSIX guarantees atomic appends for writes <= PIPE_BUF
    # (4096 bytes on Linux). Our line is well under that, so concurrent
    # captures don't interleave.
    fd = os.open(QUEUE_FILE, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
    try:
        os.write(fd, line.encode("utf-8"))
    finally:
        os.close(fd)


def main() -> None:
    # SIGALRM forces exit 0 if anything stalls past TIMEOUT_S. Available on
    # Linux + macOS; on Windows the script exits without the alarm guard
    # but Bob doesn't run there (and Claude Code hooks are linux/mac).
    if hasattr(signal, "SIGALRM"):
        signal.signal(signal.SIGALRM, _timeout_handler)
        signal.setitimer(signal.ITIMER_REAL, TIMEOUT_S)
    try:
        raw = sys.stdin.read()
        if not raw:
            return
        envelope = json.loads(raw)
        if not isinstance(envelope, dict):
            return
        event = _build_event(envelope)
        _append(event)
    except Exception:
        # Swallow everything — Bob must never see an error.
        return


if __name__ == "__main__":
    try:
        main()
    finally:
        sys.exit(0)
