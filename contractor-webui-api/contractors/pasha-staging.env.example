# contractor-webui-api environment for contractor `pasha-staging`.
# Copy to ~/.config/contractor-webui-api/pasha-staging.env on the desktop
# under the contractor's Linux user (sales-agent). Runs alongside the
# production pasha instance on a DIFFERENT port (8101 vs prod 7777).
#
# Shared-vs-separate summary (per URGENT-2026-04-23-1510 spec):
#   SEPARATE:
#     - CONTRACTOR_SLUG (drives JWT audience, CORS, and distinct read-markers)
#     - CONTRACTOR_JWT_SECRET_FILE (distinct bytes from prod's session key)
#     - CONTRACTOR_READ_DIR (staging read-state must not affect prod TUI/web)
#     - BIND_PORT (8101 so prod 7777 stays untouched)
#     - CONTRACTOR_DASH_ORIGIN (staging dash + staging Pages preview only)
#   SHARED with prod pasha (intentional — John sees staging hails too):
#     - CONTRACTOR_PUBLISH_BOX → /srv/town/shared/publish/pasha/
#     - CONTRACTOR_DOCS_DIR    → /srv/town/shared/publish/pasha/docs/

CONTRACTOR_SLUG=pasha-staging
CONTRACTOR_JWT_SECRET_FILE=/home/sales-agent/.secrets/contractor-auth-staging-pasha-session.key
CONTRACTOR_PUBLISH_BOX=/srv/town/shared/publish/pasha
CONTRACTOR_ACTIVATION_DATE=20260420

# Reading-room — shared with prod so Bob's staging edits are visible in prod
# immediately when promoted; docs themselves are persona-neutral content.
CONTRACTOR_DOCS_DIR=/srv/town/shared/publish/pasha/docs

# Staging-only read-marker dir. Keeps "unread" counts independent from prod
# so Bob clicking through messages on staging doesn't mark them read for
# Pasha on production.
CONTRACTOR_READ_DIR=/home/sales-agent/.cache/pasha-staging-dashboard/read

# Dash origins allowed to call with credentials. Staging Pages preview
# domain + staging custom domain only.
CONTRACTOR_DASH_ORIGIN=https://staging-pasha.jvholdings.co,https://contractor-dash-staging-pasha.pages.dev

# Localhost bind — Cloudflare Tunnel is the public surface. Port 8101
# deliberately differs from prod (7777) so both instances coexist on the
# same desktop without collision.
BIND_HOST=127.0.0.1
BIND_PORT=8101
