# contractor-webui-api environment for contractor `pasha`.
# Copy to ~/.config/contractor-webui-api/pasha.env on the desktop under the
# contractor's Linux user (sales-agent).

CONTRACTOR_SLUG=pasha
CONTRACTOR_JWT_SECRET_FILE=/home/sales-agent/.secrets/contractor-auth-pasha-session.key
CONTRACTOR_PUBLISH_BOX=/srv/town/shared/publish/pasha
CONTRACTOR_ACTIVATION_DATE=20260420

# Reading-room (defaults to <publish_box>/docs; explicit is fine).
CONTRACTOR_DOCS_DIR=/srv/town/shared/publish/pasha/docs

# Same read-marker dir the TUI dashboard uses, so TUI/web stay in parity.
CONTRACTOR_READ_DIR=/home/sales-agent/.cache/pasha-dashboard/read

# Dash origins allowed to call with credentials.
CONTRACTOR_DASH_ORIGIN=https://pasha.jvholdings.co,https://contractor-dash-pasha.pages.dev

# Localhost bind — Cloudflare Tunnel is the public surface.
BIND_HOST=127.0.0.1
BIND_PORT=7777
