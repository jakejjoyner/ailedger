{
  "name": "onboard-auth",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone, project-scoped auth worker. Passkeys + magic-link. Not coupled to any downstream project.",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "tail": "wrangler tail",
    "schema:apply": "wrangler d1 execute onboard_auth --file=./schema.sql",
    "schema:apply:remote": "wrangler d1 execute onboard_auth --remote --file=./schema.sql"
  },
  "dependencies": {
    "@simplewebauthn/server": "^10.0.1",
    "@tsndr/cloudflare-worker-jwt": "^3.1.4"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
